NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgres://judilen:replace-with-strong-database-password@localhost:5432/judilen
POSTGRES_PASSWORD=replace-with-strong-database-password
AUTH_SECRET=replace-with-at-least-32-random-characters
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
SEED_ADMIN_RESET_PASSWORD=false
SESSION_TTL_SECONDS=604800
NEXT_PUBLIC_SITE_URL=http://localhost:3000
UPLOAD_DIR=/app/apps/web/public/uploads
MAX_UPLOAD_BYTES=10485760
ICAL_SYNC_CRON_SECRET=replace-with-random-secret
PAYMENT_PROVIDER=disabled
PAYMENT_WEBHOOK_SECRET=replace-with-provider-secret
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=booking@example.com
